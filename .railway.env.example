# Railway 배포용 환경변수
#
# 사용법:
# 1. railway.app 대시보드 → 프로젝트 → Variables 탭
# 2. 아래 항목들을 입력
#
# 기존 로컬 .env와는 별개입니다

# Telegram Bot Token (필수)
# BotFather에서 발급: /newbot → 토큰 복사
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (선택)
# 봇에 /start 보낸 후 @userinfobot으로 ID 확인
TELEGRAM_CHAT_ID=

# Database Path (Railway 필수)
# Railway Volume이 /data 에 마운트되므로
DB_PATH=/data/paper_company.db

# Claude API Key (선택)
# 없으면 ~/.claude 디렉터리 대체
# ANTHROPIC_API_KEY=
