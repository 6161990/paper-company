[Unit]
Description=Paper Company Telegram polling bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=paper
WorkingDirectory=/opt/paper-company
EnvironmentFile=/opt/paper-company/.env
ExecStart=/opt/paper-company/.venv/bin/python scripts/telegram_poll.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
